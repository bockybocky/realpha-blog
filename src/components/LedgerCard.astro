---
import { absoluteUrl, site } from '../lib/site';
import LedgerDiscussion from './LedgerDiscussion.astro';

interface LedgerSubject {
  level: string;
  name: string;
  symbols?: string[];
}

interface LedgerCriterion {
  indicator: string;
  threshold: string;
  deadline: string;
  benchmark: string;
  data_source: string;
}

interface LedgerCardData {
  card_id: string;
  claim: string;
  claim_en: string;
  title: string;
  title_en: string;
  claim_type: 'direction' | 'macro_regime' | 'relative' | 'event';
  judge_mode: 'machine' | 'human';
  subject: LedgerSubject;
  criterion: LedgerCriterion;
  committed_at: string;
  deadline: string;
  status: 'aging' | 'hit' | 'miss' | 'undecidable';
  verdict: string | Record<string, any>;
  replay_ready_at: string;
  author_class: 'internal';
  is_sample: boolean;
}

interface Props {
  card: LedgerCardData;
  todayYmd: string;
}

const { card, todayYmd } = Astro.props;
const statusLabels = {
  aging: '熟成中',
  hit: '命中',
  miss: '證偽',
  undecidable: '條件未成立',
};
const claimTypeLabels = {
  direction: '方向',
  macro_regime: '總經 regime',
  relative: '相對強弱',
  event: '事件',
};
const judgeLabel = card.judge_mode === 'machine' ? '🤖 機器判定' : '👤 人工判定';
const verdictObject = card.verdict && typeof card.verdict === 'object' ? card.verdict : null;
const verdictSummary = typeof card.verdict === 'string' ? card.verdict : (verdictObject?.summary ?? '');
const l2Benchmark = (verdictObject?.l2_benchmark && typeof verdictObject.l2_benchmark === 'object'
  ? Object.values(verdictObject.l2_benchmark)
  : []) as Array<{ symbol: string; return_pct: number }>;

function ymdTime(value: string) {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(value)) return null;
  const [year, month, day] = value.split('-').map(Number);
  return Date.UTC(year, month - 1, day);
}

function daysUntil(value: string) {
  const target = ymdTime(value);
  const today = ymdTime(todayYmd);
  if (target === null || today === null) return null;
  return Math.ceil((target - today) / 86_400_000);
}

function formatYmd(value: string) {
  const time = ymdTime(value);
  if (time === null) return value || '未填';
  return new Intl.DateTimeFormat('zh-TW', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
  }).format(new Date(time));
}

function formatDateTime(value: string) {
  if (!value) return '以 git commit timestamp 為準';
  return new Intl.DateTimeFormat('zh-TW', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).format(new Date(value));
}

function dayBadge(value: number | null) {
  if (value === null) return '';
  if (value >= 0) return `D-${value}`;
  return `D+${Math.abs(value)}`;
}

const deadlineDays = daysUntil(card.deadline);
const replayDays = card.replay_ready_at ? daysUntil(card.replay_ready_at) : null;
const missReplayHref = verdictObject?.replay_url ?? `#${card.card_id}-verdict`;
const ratingValue = card.status === 'hit' ? 1 : card.status === 'miss' ? 0 : 0.5;
const claimReview = {
  '@context': 'https://schema.org',
  '@type': 'ClaimReview',
  '@id': absoluteUrl(`/ledger/#${card.card_id}`),
  url: absoluteUrl(`/ledger/#${card.card_id}`),
  claimReviewed: card.claim,
  datePublished: card.committed_at || undefined,
  author: {
    '@type': 'Organization',
    name: site.org,
    url: absoluteUrl('/'),
  },
  itemReviewed: {
    '@type': 'Claim',
    text: card.claim,
    datePublished: card.committed_at || undefined,
    author: {
      '@type': 'Organization',
      name: site.org,
      url: absoluteUrl('/'),
    },
  },
  reviewRating: {
    '@type': 'Rating',
    ratingValue,
    bestRating: 1,
    worstRating: 0,
    alternateName: statusLabels[card.status],
  },
};
const jsonLd = JSON.stringify(claimReview);
---

<article class={`ledger-card status-${card.status}`} id={card.card_id} data-ledger-card data-status={card.status}>
  <script type="application/ld+json" set:html={jsonLd}></script>
  <header class="card-header">
    <div class="badge-row" aria-label="卡片狀態">
      {card.is_sample && <span class="badge sample">示意卡</span>}
      <span class={`badge state state-${card.status}`}>{statusLabels[card.status]}</span>
      <span class="badge judge">{judgeLabel}</span>
      <span class="badge type">{claimTypeLabels[card.claim_type]}</span>
    </div>
    <div class="title-row">
      <p class="card-id">{card.card_id}</p>
      <h2>{card.title}</h2>
    </div>
    <p class="claim">{card.claim}</p>
  </header>

  <dl class="criterion-grid">
    <div>
      <dt>指標</dt>
      <dd>{card.criterion.indicator}</dd>
    </div>
    <div>
      <dt>門檻</dt>
      <dd>{card.criterion.threshold}</dd>
    </div>
    <div>
      <dt>期限</dt>
      <dd>
        <time datetime={card.deadline}>{formatYmd(card.deadline)}</time>
        {card.status === 'aging' && deadlineDays !== null && <span class="inline-count">{dayBadge(deadlineDays)}</span>}
      </dd>
    </div>
    <div>
      <dt>基準</dt>
      <dd>{card.criterion.benchmark}</dd>
    </div>
    <div>
      <dt>資料源</dt>
      <dd>{card.criterion.data_source}</dd>
    </div>
    <div>
      <dt>公證</dt>
      <dd>{formatDateTime(card.committed_at)}</dd>
    </div>
  </dl>

  <section class="verdict" id={`${card.card_id}-verdict`} aria-label="開獎結果">
    {card.status === 'aging' && (
      <p>這張卡仍在熟成期，期限前不改口、不刪文。</p>
    )}

    {card.status === 'miss' && (
      <div class="result-block">
        <p>{verdictSummary || '此卡已證偽，復盤內容公開可讀。'}</p>
        <a class="replay-link" href={missReplayHref}>證偽復盤：免費閱讀</a>
      </div>
    )}

    {card.status === 'hit' && (
      <div class="result-block">
        <p>{verdictSummary || '此卡已命中，深度復盤仍在第二次熟成期。'}</p>
        <span class="replay-hold">
          深度復盤：{replayDays !== null && replayDays > 0 ? `熟成中 ${dayBadge(replayDays)}` : '已熟成'}
        </span>
      </div>
    )}

    {card.status === 'undecidable' && (
      <p>{verdictSummary || '條件未成立，保留原始判準與裁決理由。'}</p>
    )}

    {l2Benchmark.length > 0 && (
      <div class="benchmark-strip" aria-label="L2 基準對照">
        {l2Benchmark.map((row) => (
          <div>
            <span>{row.symbol}</span>
            <strong>{Number(row.return_pct).toFixed(2)}%</strong>
          </div>
        ))}
      </div>
    )}
  </section>

  <LedgerDiscussion cardId={card.card_id} />
</article>

<style>
  .ledger-card {
    display: grid;
    gap: 1.15rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1rem, 3vw, 1.35rem);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--paper) 95%, transparent), color-mix(in srgb, var(--soft) 52%, var(--paper))),
      var(--paper);
    box-shadow: var(--shadow-rest);
  }

  .ledger-card + .ledger-card {
    margin-top: 1rem;
  }

  .status-hit {
    border-color: color-mix(in srgb, #16a34a 34%, var(--line));
  }

  .status-miss {
    border-color: color-mix(in srgb, #dc2626 34%, var(--line));
  }

  .status-undecidable {
    border-color: color-mix(in srgb, #ca8a04 34%, var(--line));
  }

  .card-header {
    display: grid;
    gap: 0.8rem;
  }

  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    border: 1px solid var(--line);
    border-radius: 2rem;
    padding: 0.16rem 0.6rem;
    color: var(--muted);
    background: color-mix(in srgb, var(--paper) 72%, var(--soft));
    font-size: 0.78rem;
    font-weight: 700;
  }

  .sample {
    border-color: color-mix(in srgb, #d97706 42%, var(--line));
    color: color-mix(in srgb, #b45309 82%, var(--text));
  }

  .state-aging {
    border-color: color-mix(in srgb, var(--accent) 38%, var(--line));
    color: var(--accent-strong);
  }

  .state-hit {
    border-color: color-mix(in srgb, #16a34a 42%, var(--line));
    color: #15803d;
  }

  .state-miss {
    border-color: color-mix(in srgb, #dc2626 42%, var(--line));
    color: #b91c1c;
  }

  .state-undecidable {
    border-color: color-mix(in srgb, #ca8a04 42%, var(--line));
    color: #a16207;
  }

  .title-row {
    display: grid;
    gap: 0.25rem;
  }

  .card-id {
    margin: 0;
    color: var(--muted);
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
  }

  h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 2rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .claim {
    max-width: 72ch;
    margin: 0;
    color: color-mix(in srgb, var(--text) 88%, var(--muted));
    font-size: 1.03rem;
    text-wrap: pretty;
  }

  .criterion-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
  }

  .criterion-grid div {
    min-width: 0;
    border-top: 1px solid var(--line);
    padding-top: 0.7rem;
  }

  dt {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  dd {
    margin: 0.18rem 0 0;
    color: var(--text);
    overflow-wrap: anywhere;
  }

  .inline-count {
    display: inline-flex;
    margin-left: 0.45rem;
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
    background: var(--accent-tint);
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .verdict {
    border: 1px solid color-mix(in srgb, var(--accent) 20%, var(--line));
    border-radius: var(--radius);
    padding: 0.85rem 1rem;
    background: color-mix(in srgb, var(--paper) 76%, var(--accent-tint));
  }

  .verdict p {
    margin: 0;
    color: color-mix(in srgb, var(--text) 86%, var(--muted));
  }

  .result-block {
    display: grid;
    gap: 0.65rem;
  }

  .replay-link,
  .replay-hold {
    width: max-content;
    max-width: 100%;
    border-radius: 2rem;
    padding: 0.28rem 0.7rem;
    font-weight: 700;
    font-size: 0.88rem;
  }

  .replay-link {
    border: 1px solid color-mix(in srgb, #dc2626 34%, var(--line));
    color: #b91c1c;
    text-decoration: none;
  }

  .replay-link:hover {
    background: color-mix(in srgb, #dc2626 10%, var(--paper));
  }

  .replay-hold {
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    color: var(--accent-strong);
    background: var(--accent-tint);
  }

  .benchmark-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.85rem;
  }

  .benchmark-strip div {
    display: inline-flex;
    gap: 0.4rem;
    border: 1px solid var(--line);
    border-radius: 2rem;
    padding: 0.18rem 0.55rem;
    background: color-mix(in srgb, var(--paper) 86%, var(--soft));
    font-size: 0.85rem;
  }

  .benchmark-strip span {
    color: var(--muted);
  }

  .benchmark-strip strong {
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 720px) {
    .criterion-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
