---
const { cards } = Astro.props;

const counts = cards.reduce(
  (acc, card) => {
    acc.total += 1;
    acc[card.status] = (acc[card.status] ?? 0) + 1;
    if (card.is_sample) acc.sample += 1;
    return acc;
  },
  { total: 0, hit: 0, miss: 0, aging: 0, undecidable: 0, sample: 0 },
);

const rows = [
  { key: 'hit', label: '命中', value: counts.hit },
  { key: 'miss', label: '證偽', value: counts.miss },
  { key: 'aging', label: '熟成中', value: counts.aging },
  { key: 'undecidable', label: '未成立', value: counts.undecidable },
];
---

<section class="ledger-stats" aria-label="帳本統計">
  <div class="ledger-n">
    <span class="stat-label">公開樣本</span>
    <strong>{counts.total}</strong>
    {counts.total < 20 && <span class="sample-warning">樣本不足，請先別信</span>}
    {counts.sample > 0 && <span class="sample-note">{counts.sample} 張示意卡</span>}
  </div>
  <div class="stat-grid">
    {rows.map((row) => (
      <div class={`stat-item stat-${row.key}`}>
        <span>{row.label}</span>
        <strong>{row.value}</strong>
      </div>
    ))}
  </div>
</section>

<style>
  .ledger-stats {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 2fr);
    gap: 1rem;
    align-items: stretch;
    margin: 2rem 0;
  }

  .ledger-n,
  .stat-item {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--paper) 84%, var(--soft));
    box-shadow: var(--shadow-rest);
  }

  .ledger-n {
    display: grid;
    align-content: center;
    gap: 0.45rem;
    min-height: 9rem;
    padding: 1.1rem;
  }

  .ledger-n strong {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 7vw, 4.6rem);
    line-height: 0.9;
    letter-spacing: -0.03em;
  }

  .stat-label,
  .stat-item span,
  .sample-note {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .sample-warning,
  .sample-note {
    width: max-content;
    max-width: 100%;
    border-radius: 2rem;
    padding: 0.2rem 0.65rem;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .sample-warning {
    border: 1px solid color-mix(in srgb, #d97706 45%, var(--line));
    background: color-mix(in srgb, #f59e0b 16%, var(--paper));
    color: color-mix(in srgb, #b45309 82%, var(--text));
  }

  .sample-note {
    border: 1px solid color-mix(in srgb, var(--accent) 24%, var(--line));
    background: var(--accent-tint);
    color: var(--accent-strong);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .stat-item {
    display: grid;
    align-content: center;
    gap: 0.35rem;
    min-height: 9rem;
    padding: 1rem;
  }

  .stat-item strong {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 4vw, 2.5rem);
    line-height: 1;
  }

  .stat-hit strong {
    color: #15803d;
  }

  .stat-miss strong {
    color: #b91c1c;
  }

  .stat-aging strong {
    color: var(--accent-strong);
  }

  .stat-undecidable strong {
    color: #a16207;
  }

  @media (max-width: 820px) {
    .ledger-stats {
      grid-template-columns: 1fr;
    }

    .stat-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 440px) {
    .stat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
