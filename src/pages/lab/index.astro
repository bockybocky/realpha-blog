---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getLabs } from '../../lib/content';
import { formatDate } from '../../lib/site';

const locale = 'zh-TW';
const labs = await getLabs(locale);
---

<SiteLayout title="Lab" description="Realpha Blog 的互動動畫與資料視覺化展示。" locale={locale} path="/lab/" alternatePath="/en/lab/" breadcrumbs={[{ name: 'Lab', path: '/lab/' }]}>
	<main class="page">
		<header class="section-header">
			<h1 class="page-title">Lab</h1>
			<p class="lead">小型互動 demo，頁面殼雙語，demo 本體共用。</p>
		</header>
		<div class="grid">
			{labs.map((lab) => (
				<a class="entry" href={`/lab/${lab.data.slug}/`}>
					<div class="meta"><time datetime={lab.data.pubDate.toISOString()}>{formatDate(lab.data.pubDate, locale)}</time><span>{lab.data.demo}</span></div>
					<h2>{lab.data.title}</h2>
					<p>{lab.data.description}</p>
				</a>
			))}
		</div>
	</main>
</SiteLayout>
