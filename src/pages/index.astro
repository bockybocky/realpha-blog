---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getBlogPosts, getLabs } from '../lib/content';
import { formatDate } from '../lib/site';
import ledgerCards from '../data/ledger.json';

const locale = 'zh-TW';
const posts = await getBlogPosts(locale);
const labs = await getLabs(locale);
const latest = posts.slice(0, 3);
const featuredLabs = labs.filter((lab) => lab.data.featured).slice(0, 2);

// ---- 驗證簿記錄板：讀真實 ledger 資料，樣本足夠自動升級 ----
function taipeiYmd(date: Date) {
	const parts = new Intl.DateTimeFormat('en-US', {
		timeZone: 'Asia/Taipei',
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	}).formatToParts(date);
	const get = (type: string) => parts.find((part) => part.type === type)?.value;
	return `${get('year')}-${get('month')}-${get('day')}`;
}
function ymdTime(value: string) {
	if (!/^\d{4}-\d{2}-\d{2}$/.test(value)) return null;
	const [y, m, d] = value.split('-').map(Number);
	return Date.UTC(y, m - 1, d);
}
function daysUntil(value: string, today: string) {
	const t = ymdTime(value);
	const n = ymdTime(today);
	if (t === null || n === null) return null;
	return Math.ceil((t - n) / 86_400_000);
}
function formatYmd(value: string) {
	const t = ymdTime(value);
	if (t === null) return value;
	return new Intl.DateTimeFormat('zh-TW', { month: 'short', day: '2-digit' }).format(new Date(t));
}

const todayYmd = taipeiYmd(new Date());
const nonSample = (ledgerCards as any[]).filter((c) => !c.is_sample);
const committed = nonSample.length;
const scoredCards = nonSample.filter((c) => c.status === 'scored');
const scoredCount = scoredCards.length;

// 最近一次開獎日：aging 卡中未過期最早 deadline，沒有就取整體最早
const agingDeadlines = nonSample
	.filter((c) => c.status === 'aging' && typeof c.deadline === 'string')
	.map((c) => c.deadline as string)
	.sort();
const futureDeadlines = agingDeadlines.filter((d) => d >= todayYmd);
const nextSettle = futureDeadlines[0] ?? agingDeadlines[0] ?? null;
const nextSettleDays = nextSettle ? daysUntil(nextSettle, todayYmd) : null;

// 平均 Brier（機率預報卡才有；越低越準）—— 樣本足夠時才露出
const brierVals = scoredCards
	.map((c) => Number(c?.verdict?.brier))
	.filter((n) => Number.isFinite(n));
const avgBrier = brierVals.length ? brierVals.reduce((a, b) => a + b, 0) / brierVals.length : null;

// 自動升級門檻：已開獎樣本 ≥ 20 才把門面從「機制」切成「成績」
// ponytail: 「成績」目前只露出可嚴格定義的「已開獎則數＋平均 Brier」，不捏造有爭議的「準確率 %」；
// 未來真有 20+ 已開獎樣本、且定好各卡型 hit 語意後，再決定要不要加通過率。
const showScore = scoredCount >= 20;
---

<SiteLayout title="Realpha Blog" description="Realpha、Bocky 與 AI 研究團隊的雙語技術與投資研究筆記。" locale={locale} path="/" alternatePath="/en/">
	<main class="page">
		<section class="hero" aria-labelledby="home-title">
			<h1 id="home-title">在 AI 時代，觀點已經氾濫，但驗證還是<span class="mark">稀缺</span>。</h1>
			<p class="hero-lede">Realpha 是一間公開實驗室：每個市場判讀在發表當下就公證、鎖死判準、標好開獎日。到期用數據對答案——通過的留下，被推翻的置頂認錯。</p>

			<div class="record" aria-label="驗證簿記錄板">
				<div class="record-num">
					{showScore ? (
						<>
							<span class="eyebrow">公開成績</span>
							<span class="big">{scoredCount} <small>則已開獎</small></span>
							{avgBrier !== null && <span class="sub">平均 Brier {avgBrier.toFixed(3)}（越低越準，亂猜約 0.25）</span>}
						</>
					) : (
						<>
							<span class="eyebrow">已上鎖的判讀</span>
							<span class="big">{committed} <small>則</small></span>
							<span class="sub">判準已鎖死・開獎日已標</span>
						</>
					)}
				</div>
				<div class="record-body">
					<div class="steps">
						<span class="step"><span class="dot"></span>發表即公證</span>
						<span class="step-arrow" aria-hidden="true">→</span>
						<span class="step"><span class="dot"></span>鎖死判準（改字即作廢）</span>
						<span class="step-arrow" aria-hidden="true">→</span>
						<span class="step"><span class="dot"></span>到期用數據開獎</span>
					</div>
					<div class="badges">
						{nextSettle && (
							<span class="badge live">
								<span class="live-dot" aria-hidden="true"></span>
								最近開獎：{formatYmd(nextSettle)}
								{nextSettleDays !== null && nextSettleDays >= 0 && <> · 還有 {nextSettleDays} 天</>}
							</span>
						)}
						{!showScore && <span class="badge warn">樣本不足，請先別信</span>}
					</div>
					<div class="cta-row">
						<a class="cta primary" href="/ledger/">看驗證簿 →</a>
						<a class="cta ghost" href="/propose/">來反證我</a>
					</div>
				</div>
			</div>
		</section>

		<section class="section" aria-labelledby="latest-title">
			<div class="section-header">
				<h2 id="latest-title">最新研究</h2>
				<p class="muted">方法、實驗與市場判讀——寫完就攤在這裡，等時間驗證。</p>
			</div>
			<div class="grid">
				{latest.map((post) => (
					<a class={`entry${post.data.cover ? ' has-cover' : ''}`} href={`/blog/${post.data.slug}/`}>
						{post.data.cover && (
							<div class="entry-cover">
								<img src={post.data.cover} alt={post.data.title} loading="lazy" decoding="async" width="800" height="450" />
							</div>
						)}
						<div class="meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time></div>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
						<ul class="tag-list">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
					</a>
				))}
			</div>
		</section>

		<section class="section" aria-labelledby="lab-title">
			<div class="section-header">
				<h2 id="lab-title">動手玩 Lab</h2>
				<p class="muted">資料不是拿來讀的，是拿來戳的——這裡的圖會動，假設可以親手驗。</p>
			</div>
			<div class="grid">
				{featuredLabs.map((lab) => (
					<a class="entry" href={`/lab/${lab.data.slug}/`}>
						<span class="pill">Demo</span>
						<h3>{lab.data.title}</h3>
						<p>{lab.data.description}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</SiteLayout>

<style>
	/* 首頁最新文章封面（同 /blog 列表：滿版縮圖破出卡片 padding、圓上緣、16:9、lazy） */
	.entry.has-cover { padding-top: 0; }
	.entry-cover {
		margin: 0 -1.25rem 0.25rem;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius) var(--radius) 0 0;
		background: color-mix(in srgb, var(--soft) 60%, var(--paper));
	}
	.entry-cover img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.35s ease; }
	.entry.has-cover:hover .entry-cover img { transform: scale(1.03); }

	/* 驗證簿記錄板（hero 底，機制優先、誠實徽章） */
	.hero-lede { color: var(--muted); max-width: 52ch; }
	.record {
		margin-top: 1.8rem;
		border-top: 1px solid var(--line);
		padding-top: 1.5rem;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1.3rem 1.9rem;
		align-items: start;
	}
	@media (max-width: 620px) { .record { grid-template-columns: 1fr; } }

	.record-num { display: flex; flex-direction: column; gap: 0.18rem; }
	.record-num .eyebrow {
		margin: 0;
		font-size: 0.75rem; font-weight: 800; letter-spacing: 0.07em;
		text-transform: uppercase; color: var(--muted);
	}
	.record-num .big {
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 6.5vw, 3.4rem);
		font-weight: 700; line-height: 1; letter-spacing: -0.03em;
		font-variant-numeric: tabular-nums; color: var(--text);
	}
	.record-num .big small { font-size: 0.9rem; font-weight: 600; color: var(--muted); letter-spacing: 0; }
	.record-num .sub { font-size: 0.85rem; color: var(--muted); }

	.record-body { display: flex; flex-direction: column; gap: 1rem; }

	.steps { display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem 0.5rem; }
	.steps .step {
		display: inline-flex; align-items: center; gap: 0.4rem;
		font-size: 0.85rem; font-weight: 600; color: var(--text);
		background: var(--soft); border: 1px solid var(--line);
		border-radius: 2rem; padding: 0.28rem 0.75rem;
	}
	.steps .step .dot { width: 0.5rem; height: 0.5rem; border-radius: 50%; background: var(--accent); }
	.step-arrow { color: var(--muted); font-size: 0.85rem; }

	.badges { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.badge {
		display: inline-flex; align-items: center; gap: 0.45rem;
		border-radius: 2rem; padding: 0.3rem 0.8rem; font-size: 0.82rem; font-weight: 700;
	}
	.badge.live {
		border: 1px solid color-mix(in srgb, var(--accent) 40%, var(--line));
		background: var(--accent-tint); color: var(--accent-strong);
		font-variant-numeric: tabular-nums;
	}
	.badge.warn {
		border: 1px solid color-mix(in srgb, #d97706 55%, var(--line));
		background: color-mix(in srgb, #f59e0b 16%, var(--paper));
		color: color-mix(in srgb, #b45309 82%, var(--text));
	}
	.live-dot {
		width: 0.55rem; height: 0.55rem; border-radius: 50%; background: var(--accent);
		animation: record-pulse 2.2s infinite;
	}
	@keyframes record-pulse {
		0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent) 55%, transparent); }
		70% { box-shadow: 0 0 0 7px transparent; }
		100% { box-shadow: 0 0 0 0 transparent; }
	}
	@media (prefers-reduced-motion: reduce) { .live-dot { animation: none; } }

	.cta-row { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 0.15rem; }
	.cta {
		display: inline-flex; align-items: center; gap: 0.4rem; text-decoration: none;
		font-weight: 700; font-size: 0.9rem; border-radius: var(--radius);
		padding: 0.55rem 1rem; transition: transform 0.15s ease;
	}
	.cta.primary { background: var(--accent); color: #fff; }
	@media (prefers-color-scheme: dark) { .cta.primary { color: #0d1117; } }
	.cta.ghost { border: 1px solid var(--line); color: var(--text); background: var(--paper); }
	.cta:hover { transform: translateY(-1px); }
</style>
