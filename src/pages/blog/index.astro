---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getBlogPosts } from '../../lib/content';
import { formatDate } from '../../lib/site';

const locale = 'zh-TW';
const posts = await getBlogPosts(locale);
---

<SiteLayout title="文章" description="Realpha Blog 的繁中技術、系統與投資研究文章。" locale={locale} path="/blog/" alternatePath="/en/blog/" breadcrumbs={[{ name: '文章', path: '/blog/' }]}>
	<main class="page">
		<header class="section-header">
			<h1 class="page-title">文章</h1>
			<p class="lead">每篇文章都提供雙語頁面、RSS 入口與純 Markdown 版本。</p>
		</header>
		<div class="grid">
			{posts.map((post) => (
				<a class="entry" href={`/blog/${post.data.slug}/`}>
					<div class="meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time><span>{post.data.category}</span></div>
					<h2>{post.data.title}</h2>
					<p>{post.data.description}</p>
					<ul class="tag-list">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
				</a>
			))}
		</div>
	</main>
</SiteLayout>
