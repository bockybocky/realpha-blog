---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getBlogPosts } from '../../lib/content';
import { formatDate } from '../../lib/site';

const locale = 'zh-TW';
const posts = await getBlogPosts(locale);
---

<SiteLayout title="研究筆記" description="Realpha Blog 的繁中技術、系統與投資研究文章。" locale={locale} path="/blog/" alternatePath="/en/blog/" breadcrumbs={[{ name: '研究筆記', path: '/blog/' }]}>
	<main class="page">
		<header class="section-header">
			<h1 class="page-title">研究筆記</h1>
			<p class="lead">寫給人讀，也寫給 AI 引用——所以每個主張都留了出處、判準和被推翻的可能。</p>
		</header>
		<div class="grid">
			{posts.map((post) => (
				<a class={`entry${post.data.cover ? ' has-cover' : ''}`} href={`/blog/${post.data.slug}/`}>
						{post.data.cover && (
							<div class="entry-cover">
								<img src={post.data.cover} alt={post.data.title} loading="lazy" decoding="async" width="800" height="450" />
							</div>
						)}
					<div class="meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time><span>{post.data.category}</span></div>
					<h2>{post.data.title}</h2>
					<p>{post.data.description}</p>
					<ul class="tag-list">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
				</a>
			))}
		</div>
	</main>
</SiteLayout>

<style>
	/* B 版雜誌感封面：滿版縮圖破出卡片 padding、圓上緣、16:9、lazy */
	.entry.has-cover { padding-top: 0; }
	.entry-cover {
		margin: 0 -1.25rem 0.25rem;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius) var(--radius) 0 0;
		background: color-mix(in srgb, var(--soft) 60%, var(--paper));
	}
	.entry-cover img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.35s ease; }
	.entry.has-cover:hover .entry-cover img { transform: scale(1.03); }
</style>
