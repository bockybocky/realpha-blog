---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getBlogPosts } from '../../../lib/content';
import { formatDate } from '../../../lib/site';

const locale = 'en';
const posts = await getBlogPosts(locale);
---

<SiteLayout title="Blog" description="English technical, systems, and investment research posts from Realpha Blog." locale={locale} path="/en/blog/" alternatePath="/blog/" breadcrumbs={[{ name: 'Blog', path: '/en/blog/' }]}>
	<main class="page">
		<header class="section-header">
			<h1 class="page-title">Blog</h1>
			<p class="lead">Every post ships with paired language pages, RSS, and raw Markdown output.</p>
		</header>
		<div class="grid">
			{posts.map((post) => (
				<a class={`entry${post.data.cover ? ' has-cover' : ''}`} href={`/en/blog/${post.data.slug}/`}>
						{post.data.cover && (
							<div class="entry-cover">
								<img src={post.data.cover} alt={post.data.title} loading="lazy" decoding="async" width="800" height="450" />
							</div>
						)}
					<div class="meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time><span>{post.data.category}</span></div>
					<h2>{post.data.title}</h2>
					<p>{post.data.description}</p>
					<ul class="tag-list">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
				</a>
			))}
		</div>
	</main>
</SiteLayout>

<style>
	.entry.has-cover { padding-top: 0; }
	.entry-cover {
		margin: 0 -1.25rem 0.25rem;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		border-radius: var(--radius) var(--radius) 0 0;
		background: color-mix(in srgb, var(--soft) 60%, var(--paper));
	}
	.entry-cover img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.35s ease; }
	.entry.has-cover:hover .entry-cover img { transform: scale(1.03); }
</style>
