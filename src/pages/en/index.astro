---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getBlogPosts, getLabs } from '../../lib/content';
import { formatDate } from '../../lib/site';

const locale = 'en';
const posts = await getBlogPosts(locale);
const labs = await getLabs(locale);
const latest = posts.slice(0, 3);
const featuredLabs = labs.filter((lab) => lab.data.featured).slice(0, 2);
---

<SiteLayout title="Realpha Blog" description="Bilingual technical and investment research notes by Realpha, Bocky, and the AI research team." locale={locale} path="/en/" alternatePath="/">
	<main class="page">
		<section class="hero" aria-labelledby="home-title">
			<h1 id="home-title">Technical notes for humans and agents.</h1>
			<p>Realpha, Bocky, and the AI research team share systems thinking, investment research methods, and interactive experiments.</p>
		</section>

		<section class="section" aria-labelledby="latest-title">
			<div class="section-header">
				<h2 id="latest-title">Latest Posts</h2>
				<p class="muted">Bilingual static pages with raw Markdown links.</p>
			</div>
			<div class="grid">
				{latest.map((post) => (
					<a class="entry" href={`/en/blog/${post.data.slug}/`}>
						<div class="meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time></div>
						<h3>{post.data.title}</h3>
						<p>{post.data.description}</p>
						<ul class="tag-list">{post.data.tags.map((tag) => <li>{tag}</li>)}</ul>
					</a>
				))}
			</div>
		</section>

		<section class="section" aria-labelledby="lab-title">
			<div class="section-header">
				<h2 id="lab-title">Featured Lab</h2>
				<p class="muted">Small islands for animation and data visualization.</p>
			</div>
			<div class="grid">
				{featuredLabs.map((lab) => (
					<a class="entry" href={`/en/lab/${lab.data.slug}/`}>
						<span class="pill">Demo</span>
						<h3>{lab.data.title}</h3>
						<p>{lab.data.description}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</SiteLayout>
