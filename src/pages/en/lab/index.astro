---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getBlogPosts, getLabs } from '../../../lib/content';
import { formatDate } from '../../../lib/site';

const locale = 'en';
const posts = await getBlogPosts(locale);
const labPosts = posts.filter((post) => post.data.category === 'lab');
const labs = await getLabs(locale);
---

<SiteLayout title="Public Lab" description="Realpha Blog publishes hypotheses, validation plans, and timestamps before experiments run, then publishes results regardless of outcome." locale={locale} path="/en/lab/" alternatePath="/lab/" breadcrumbs={[{ name: 'Lab', path: '/en/lab/' }]}>
	<main class="page">
		<header class="section-header">
			<h1 class="page-title">Public Lab</h1>
			<p class="lead">The public lab publishes hypotheses, validation plans, and timestamps before an experiment runs, then publishes results regardless of outcome. Readers are invited to challenge assumptions, rebut the setup, or pressure-test the design before the results are in.</p>
		</header>
		{labPosts.length > 0 && (
			<section class="section" aria-labelledby="lab-posts-title">
				<div class="section-header">
					<h2 id="lab-posts-title">Preregistration Records</h2>
					<p class="muted">Hypotheses, validation plans, and results stay in one public record.</p>
				</div>
				<div class="grid">
					{labPosts.map((post) => (
						<a class="entry" href={`/en/blog/${post.data.slug}/`}>
							<div class="meta"><time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate, locale)}</time><span>{post.data.result}</span></div>
							<h2>{post.data.title}</h2>
							<p>{post.data.description}</p>
						</a>
					))}
				</div>
			</section>
		)}
		<section class="section" aria-labelledby="lab-demos-title">
			<div class="section-header">
				<h2 id="lab-demos-title">Interactive Demos</h2>
				<p class="muted">Small interactive demos with bilingual page shells and shared demo code.</p>
			</div>
			<div class="grid">
				{labs.map((lab) => (
					<a class="entry" href={`/en/lab/${lab.data.slug}/`}>
						<div class="meta"><time datetime={lab.data.pubDate.toISOString()}>{formatDate(lab.data.pubDate, locale)}</time><span>{lab.data.demo}</span></div>
						<h2>{lab.data.title}</h2>
						<p>{lab.data.description}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</SiteLayout>
